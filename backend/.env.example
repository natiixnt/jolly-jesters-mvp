# === Baza danych ===
DB_URL=postgresql+psycopg2://mvp:mvp@postgres:5432/mvpdb

# === Redis / Celery ===
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=${REDIS_URL}
CELERY_RESULT_BACKEND=${REDIS_URL}

# === Bezpieczenstwo ===
JWT_SECRET=your-secret-here-min-32-chars
UI_PASSWORD=change-me-strong-password
UI_BASIC_AUTH_USER=admin
UI_BASIC_AUTH_PASSWORD=change-me
UI_SESSION_TTL_HOURS=24
COOKIE_SECURE=false
CORS_ORIGINS=http://localhost,http://localhost:80
REGISTRATION_KEY=your-registration-key

# === Profil rownoleglosci 3x3 (Etap 1, zad. 1.4.1) ===
CONCURRENCY_PER_USER=3
CONCURRENCY_GLOBAL_MAX=12
MAX_CONCURRENT_RUNS=3
CELERY_CONCURRENCY=3

# === Mechanizm stop-loss (Etap 1, zad. 1.6.1) ===
# Progi konfigurowane przez UI w /settings, wartosci domyslne ponizej
# stoploss_max_error_rate=0.50
# stoploss_max_captcha_rate=0.80
# stoploss_max_consecutive_errors=10
# stoploss_max_retry_rate=0.05
# stoploss_max_blocked_rate=0.10
# stoploss_max_cost_per_1000=10.0

# === Metering kosztu (Etap 1, zad. 1.2.3) ===
COST_RATE_NETWORK_PER_GB=12.53
COST_RATE_ACCESS_VERIFICATION=5.19
CAPTCHA_COST_USD=0.002

# === Warstwa dostepu sieciowego (Etap 1, zad. 1.5) ===
NETWORK_HEALTHCHECK_INTERVAL=5
NETWORK_QUARANTINE_TTL=24

# === Scraper Allegro ===
ALLEGRO_SCRAPER_URL=http://allegro_scraper:3000
ALLEGRO_SCRAPER_POLL_INTERVAL=2.0
ALLEGRO_SCRAPER_TIMEOUT_SECONDS=90
SCRAPER_WORKER_COUNT=3
SCRAPER_CONCURRENCY_PER_WORKER=3
SCRAPER_MAX_TASK_RETRIES=2
SCRAPER_MAX_PENDING_TASKS=100

# === Captcha solver (wymagane) ===
ANYSOLVER_API_KEY=replace-with-your-key

# === Analiza rentownosci ===
PROFITABILITY_MIN_PROFIT_PLN=5.0
PROFITABILITY_MIN_SALES=10
PROFITABILITY_MAX_COMPETITION=50
EUR_TO_PLN_RATE=4.5

# === Srodowisko ===
ENVIRONMENT=dev
WORKSPACE=/workspace
SCRAPER_PROXIES_FILE=/workspace/data/proxies.txt
LOG_FORMAT=text
LOG_LEVEL=INFO

# === Alerty (opcjonalne) ===
ALERT_WEBHOOK_URL=
NOTIFICATION_WEBHOOK_URL=

# === Cloudflare Tunnel (opcjonalne) ===
TUNNEL_TOKEN=

# === Opcjonalne inline proxy (preferowane wgranie pliku przez UI) ===
# PROXIES=http://user:pass@host:port,https://user:pass@host2:port
